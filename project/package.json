{
    "name": "seazit",
    "version": "1.0.0",
    "description": "add-me",
    "repository": "add-me",
    "license": "add-me",
    "scripts": {
        "clean": "./node_modules/.bin/rimraf ./static_seazit/bundles/* && ./node_modules/.bin/rimraf ./webpack-stats.json",
        "build": "npm run clean && npm run build:production",
        "build:production": "NODE_ENV=production ./node_modules/.bin/webpack --config webpack.config.prod.js",
        "build:dev": "webpack --config webpack.config.dev.js",
        "precommit": "lint-staged",
        "start": "webpack-dashboard -- node webpack.devServer.js",
        "start-plain": "node webpack.devServer.js",
        "lint": "eslint assets",
        "prettify": "prettier --config=./.prettierrc --write \"**/*.{js,css}\""
    },
    "lint-staged": {
        "*.{js,json,css}": [
            "prettier --write",
            "git add"
        ]
    },
